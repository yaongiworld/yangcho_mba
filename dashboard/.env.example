# Supabase project — public envs (safe in client bundle)
# Per Supabase's 2025 key model: publishable keys (`sb_publishable_...`)
# respect RLS; never ship a secret key from the dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_KEY

# Used only by `npm run db:types`
SUPABASE_PROJECT_ID=YOUR_PROJECT_REF
